class Board:
    def __init__(self, black_bits: int, white_bits: int, side_to_move: str) -> None: ...
    @staticmethod
    def new_initial() -> Board: ...
    @property
    def black_bits(self) -> int: ...
    @property
    def white_bits(self) -> int: ...
    @property
    def side_to_move(self) -> str: ...
    def to_bits(self) -> tuple[int, int, str]: ...

def initial_board() -> Board: ...
def board_from_bits(black_bits: int, white_bits: int, side_to_move: str) -> Board: ...
def generate_legal_moves(board: Board) -> int: ...
def generate_legal_moves_bits(black_bits: int, white_bits: int, side_to_move: str) -> int: ...
def apply_move_unchecked(board: Board, square: int) -> Board: ...
def apply_move_unchecked_bits(
    black_bits: int, white_bits: int, side_to_move: str, square: int
) -> tuple[int, int, str]: ...
def apply_move(board: Board, square: int) -> Board: ...
def apply_move_bits(
    black_bits: int, white_bits: int, side_to_move: str, square: int
) -> tuple[int, int, str]: ...
